{
  "name": "infrawatch-backend",
  "version": "1.0.0",
  "description": "InfraWatch MVP backend",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": "20.x",
    "npm": ">=10"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:docker": "prisma migrate deploy && node dist/server.js",
    "dev": "tsx watch server.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --runInBand",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy"
  },
  "jest": {
    "testEnvironment": "node",
    "preset": "ts-jest/presets/default-esm",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "./tsconfig.json"
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "axios": "^1.7.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "jsonwebtoken": "^9.0.3",
    "net-snmp": "^3.26.1",
    "node-telegram-bot-api": "^0.64.0",
    "nodemailer": "^7.0.11",
    "ping": "^0.4.4",
    "prisma": "^6.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.22",
    "@types/node-telegram-bot-api": "^0.64.8",
    "@types/nodemailer": "^7.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
