PORT=3001
DATABASE_URL="postgresql://infrawatch:infrawatch@localhost:5433/infrawatch?schema=public"
# Redis cache and distributed session store (Week 2 - P1)
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
REDIS_SESSION_ENABLED=true
# Bull worker queue (Week 2 - P1)
WORKER_QUEUE_ENABLED=false
MONITOR_WORKER_CONCURRENCY=5
NOTIFY_WORKER_CONCURRENCY=8
# Authentication (required)
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=8h
ADMIN_EMAIL=admin@empresa.com
ADMIN_PASSWORD=changeme123
ADMIN_ROLE=admin
# Email notifications (optional)
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_TO=admin@example.com
# Telegram notifications (optional)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
# SMS notifications (Twilio, optional)
SMS_ENABLED=false
SMS_PROVIDER=twilio
SMS_TWILIO_ACCOUNT_SID=your-account-sid
SMS_TWILIO_AUTH_TOKEN=your-auth-token
SMS_FROM=+10000000000
SMS_TO=+244900000001,+244900000002
# Push notifications (FCM or webhook, optional)
PUSH_ENABLED=false
PUSH_PROVIDER=fcm
PUSH_FCM_SERVER_KEY=your-fcm-server-key
PUSH_FCM_DEVICE_TOKENS=token1,token2
PUSH_FCM_TOPIC=
PUSH_WEBHOOK_URL=
PUSH_WEBHOOK_AUTH_TOKEN=
# External integrations (Week 2 - P1)
INTEGRATIONS_WEBHOOK_SECRET=
GLPI_ENABLED=false
GLPI_WEBHOOK_URL=
GLPI_WEBHOOK_TOKEN=
DOCUWARE_ENABLED=false
DOCUWARE_WEBHOOK_URL=
DOCUWARE_WEBHOOK_TOKEN=
# Fallback monitoring interval in milliseconds (used when device interval is not set)
MONITOR_INTERVAL=5000
