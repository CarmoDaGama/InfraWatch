PORT=3001
DATABASE_URL="file:../data/infrawatch.db"
# Authentication (required)
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=8h
ADMIN_EMAIL=admin@empresa.com
ADMIN_PASSWORD=changeme123
ADMIN_ROLE=admin
# Email notifications (optional)
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_TO=admin@example.com
# Telegram notifications (optional)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
# SMS notifications (Twilio, optional)
SMS_ENABLED=false
SMS_PROVIDER=twilio
SMS_TWILIO_ACCOUNT_SID=your-account-sid
SMS_TWILIO_AUTH_TOKEN=your-auth-token
SMS_FROM=+10000000000
SMS_TO=+244900000001,+244900000002
# Push notifications (FCM or webhook, optional)
PUSH_ENABLED=false
PUSH_PROVIDER=fcm
PUSH_FCM_SERVER_KEY=your-fcm-server-key
PUSH_FCM_DEVICE_TOKENS=token1,token2
PUSH_FCM_TOPIC=
PUSH_WEBHOOK_URL=
PUSH_WEBHOOK_AUTH_TOKEN=
# Fallback monitoring interval in milliseconds (used when device interval is not set)
MONITOR_INTERVAL=5000
